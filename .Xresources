! DPI: http://dpi.lv/
xft*dpi: 94
xft*antialias: true
xft*rgba: rgb
xft*hinting: true
xft*hintstyle: hintslight
xft*autohint: 1
xft*lcdfilter: lcddefault

xterm*faceName: Latin Modern Mono:size=12
xterm*termName: xterm-256color
xterm*VT100.geometry: 100x60
xterm*foreground: white
xterm*background: black
xterm*saveLines: 65536 
xterm*multiScroll: true
xterm*jumpScroll: true
xterm*scrollBar: false
! Scroll down when a key is pressed.
xterm*scrollKey: true
xterm*xftAntialias: true
xterm*renderFont: true
! Make certain your locale settings are correct for UTF-8. This line will then make
! XTerm interpret all incoming data as UTF-8 encoded.
xterm*locale: true
xterm*utf8: 1
xterm*cursorblink: false
! Fix alt-key inputting.
xterm*eightBitInput: false
xterm*metaSendsEscape: true
! Do not scroll with new terminal output.
xterm*scrollTtyOutput: false
! Allow selecting email/URL by double-clicking.
xterm*charClass: 33:48,37-38:48,45-47:48,64:48,58:48,126:48,61:48,63:48,43:48,35:48

urxvt*font: xft:Liberation Mono:pixelsize=12
urxvt*boldFont: xft:Liberation Mono:pixelsize=12:style=Bold
urxvt*italicFont: xft:Liberation Mono:pixelsize=12:style=Italic
urxvt*boldItalicFont: xft:Liberation Mono:pixelsize=12:style=Bold:style=Italic
urxvt*termName: xterm-256color
urxvt*geometry:100x60
! Needed for true transparency. The window manager also needs to support
! compositing or a separate compositor.
urxvt*depth: 32
urxvt*internalBorder: 3
urxvt*externalBorder: 0
! Fade the text by the given percentage when focus is lost.
urxvt*fading: 10
urxvt*tintColor: white
urxvt*saveLines: 65536
urxvt*scrollBar: true
urxvt*scrollstyle: plain
urxvt*scrollColor: #3A3A3A
urxvt*foreground: white
! The alpha values control the transparency.
urxvt*background: rgba:1111/1111/1111/dddd
! Disable the CTRL+SHIFT shortcut that enters ISO14755 mode.
urxvt*iso14755: false
! Do not scroll with new terminal output.
urxvt*scrollTtyOutput: false
! Scroll in relation to buffer (with mouse scroll or Shift+Page Up/Down).
urxvt*scrollWithBuffer: true
! Scroll to the bottom on key press.
urxvt*scrollTtyKeypress: true 
! By default, URxvt uses the same colors as XTerm except one. Set this to
! make the colors identical to that of XTerm.
urxvt*color12: rgb:5c/5c/ff

aterm*background: black
aterm*foreground: yellow
aterm*transparent: true
aterm*shading: 30
aterm*cursorColor: gray
aterm*saveLines: 65536
aterm*scrollBar: false
aterm*transpscrollbar: true
